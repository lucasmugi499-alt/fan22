rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function role() {
      return signedIn() ? request.auth.token.role : null;
    }

    function isAdmin() {
      return role() == 'platform_admin' || role() == 'super_admin';
    }

    function validMedia() {
      return request.resource != null &&
        request.resource.size < 50 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*|video/.*');
    }

    match /users/{userId}/{allPaths=**} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow create, update: if signedIn() && request.auth.uid == userId && validMedia();
      allow delete: if isAdmin() || (signedIn() && request.auth.uid == userId);
    }

    match /approvedMedia/{allPaths=**} {
      allow read: if true;
      allow create, update: if isAdmin() && validMedia();
      allow delete: if isAdmin();
    }

    match /public/{allPaths=**} {
      allow read: if true;
      allow create, update: if signedIn() && validMedia();
      allow delete: if isAdmin();
    }

    match /moderation/{allPaths=**} {
      allow read, write: if isAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if role() == 'super_admin';
    }
  }
}
